# Copy this file to .env and fill in your actual values
# Do NOT commit the real .env file - it contains secret keys

STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
FRONTEND_URL=http://localhost:3000

# When you add Upstash Redis in Vercel Integrations, it will automatically
# provide the following keys in your deployment environment. 
# For local development with 'vercel dev', you can pull them automatically using:
# 'vercel env pull' OR you can paste them here manually:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
